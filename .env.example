# SafEnergy local service access template.
#
# Copy this file to `.env` for local runs. Keep `.env`, downloaded provider
# credentials, OAuth tokens, cache files, raw satellite scenes, and generated
# model artifacts out of version control.

# ---------------------------------------------------------------------------
# Local runtime
# ---------------------------------------------------------------------------

SAFENERGY_ENV=local
SAFENERGY_LOG_LEVEL=INFO
SAFENERGY_TIMEZONE=UTC
SAFENERGY_DATA_DIR=data
SAFENERGY_CACHE_DIR=data/cache

# ---------------------------------------------------------------------------
# Satellite access
# ---------------------------------------------------------------------------
#
# MVP recommendation: use Google Earth Engine for Sentinel/Copernicus-backed
# satellite features. Earth Engine user auth is initialized outside this file
# with `ee.Authenticate()` and `ee.Initialize(project=...)`.

EE_PROJECT=

# Server/service-account alternative for Earth Engine. This value is a local
# path only. Do not commit the referenced JSON file.
GOOGLE_APPLICATION_CREDENTIALS=

# Alternative direct Sentinel product access through Copernicus Data Space.
# Prefer generating short-lived access tokens at runtime and caching them under
# `SAFENERGY_CACHE_DIR` instead of storing bearer tokens in `.env`.
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=

# Alternative Sentinel Hub Process API access. Required only if the project
# uses Sentinel Hub instead of Earth Engine or direct Copernicus downloads.
SENTINELHUB_CLIENT_ID=
SENTINELHUB_CLIENT_SECRET=

# Optional EUMETSAT access path, if a future ingestion adapter uses EUMDAC.
EUMETSAT_CONSUMER_KEY=
EUMETSAT_CONSUMER_SECRET=

# ---------------------------------------------------------------------------
# Weather and solar resources
# ---------------------------------------------------------------------------
#
# Open-Meteo does not require an API key for the intended MVP usage, so there
# is intentionally no OPEN_METEO_API_KEY setting.
#
# NASA POWER and pvlib are expected to be used without project secrets unless a
# future adapter documents a provider-specific credential requirement.

# ---------------------------------------------------------------------------
# Market, generation, and news data
# ---------------------------------------------------------------------------
#
# These are optional and should stay blank until the corresponding integration
# is implemented. No live trading or order-submission credentials belong here.

ENTSOE_API_TOKEN=
EIA_API_KEY=

# Optional local path for pre-downloaded challenge, market, or provider data.
SAFENERGY_FIXTURE_DATA_DIR=data/fixtures
